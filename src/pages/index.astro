---
import Layout from '../layouts/Layout.astro'

const base = import.meta.env.BASE_URL

const topics = [
  {
    href: `${base}basics`,
    icon: '📦',
    title: 'Git の基本',
    description: 'init・add・commit の使い方。ファイルの変更履歴を記録する第一歩を学ぼう。',
    color: 'from-orange-50 to-orange-100',
    border: 'border-orange-200',
    text: 'text-orange-600',
  },
  {
    href: `${base}branch`,
    icon: '🌿',
    title: 'ブランチ',
    description: '並行開発を可能にするブランチの作成・切り替え・マージを学ぼう。',
    color: 'from-green-50 to-green-100',
    border: 'border-green-200',
    text: 'text-green-600',
  },
  {
    href: `${base}about-github`,
    icon: '🐙',
    title: 'GitHub とは',
    description: 'GitHubとGitの違い・できること・アカウント作成・主要な用語を理解しよう。',
    color: 'from-purple-50 to-purple-100',
    border: 'border-purple-200',
    text: 'text-purple-600',
  },
  {
    href: `${base}github`,
    icon: '📡',
    title: 'GitHub 基本操作',
    description: 'リモートリポジトリへの push・pull・clone を使ってチームで共有しよう。',
    color: 'from-indigo-50 to-indigo-100',
    border: 'border-indigo-200',
    text: 'text-indigo-600',
  },
  {
    href: `${base}pullrequest`,
    icon: '🔀',
    title: 'プルリクエスト',
    description: 'コードレビューの仕組み。変更をチームに提案してマージしてもらおう。',
    color: 'from-blue-50 to-blue-100',
    border: 'border-blue-200',
    text: 'text-blue-600',
  },
  {
    href: `${base}workflow`,
    icon: '🔄',
    title: '実践ワークフロー',
    description: '実際の開発現場で使われる Git Flow を通して全体の流れをつかもう。',
    color: 'from-pink-50 to-pink-100',
    border: 'border-pink-200',
    text: 'text-pink-600',
  },
  {
    href: `${base}issue-driven`,
    icon: '📋',
    title: 'Issue 駆動開発',
    description: 'Issue から作業を始める開発スタイル。よくある事例 5 選でまるごと理解しよう。',
    color: 'from-teal-50 to-teal-100',
    border: 'border-teal-200',
    text: 'text-teal-600',
  },
]

const commands = [
  { cmd: 'git init', desc: 'リポジトリを作成' },
  { cmd: 'git add .', desc: '変更をステージング' },
  { cmd: 'git commit -m "msg"', desc: '変更を記録' },
  { cmd: 'git push origin main', desc: 'GitHubに送る' },
  { cmd: 'git pull', desc: '最新を取得' },
  { cmd: 'git branch', desc: 'ブランチ一覧' },
]
---

<Layout title="ホーム">
  <!-- ヒーロー -->
  <section class="relative overflow-hidden bg-gradient-to-br from-orange-50 via-white to-slate-100 py-24 px-4 border-b border-gray-200">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_rgba(249,115,22,0.08),_transparent_60%)]"></div>
    <div class="max-w-4xl mx-auto text-center relative">
      <div class="inline-flex items-center gap-2 bg-orange-50 border border-orange-200 rounded-full px-4 py-2 text-orange-600 text-sm font-medium mb-8">
        <span>🚀</span>
        <span>初心者向け Git & GitHub 完全ガイド</span>
      </div>
      <h1 class="text-5xl md:text-6xl font-extrabold text-gray-900 mb-6 leading-tight">
        Git と GitHub を<br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-500 to-pink-500">
          ゼロから学ぼう
        </span>
      </h1>
      <p class="text-xl text-gray-600 mb-10 max-w-2xl mx-auto leading-relaxed">
        バージョン管理の基礎から、チームでの実践的なワークフローまで。<br />
        豊富なコマンド例と図解でわかりやすく解説します。
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={`${base}basics`}
           class="bg-orange-500 hover:bg-white hover:text-orange-500 text-white font-semibold px-8 py-3 rounded-xl border border-orange-500 transition-colors">
          学習を始める →
        </a>
        <a href={`${base}workflow`}
           class="bg-white hover:bg-gray-900 hover:text-white text-gray-900 font-semibold px-8 py-3 rounded-xl border border-gray-300 transition-colors">
          ワークフローを見る
        </a>
      </div>
    </div>
  </section>

  <!-- よく使うコマンド一覧 -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <h2 class="text-center text-sm font-semibold text-gray-400 uppercase tracking-widest mb-8">
      よく使う Git コマンド
    </h2>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3">
      {commands.map(({ cmd, desc }) => (
        <div class="bg-white border border-gray-200 rounded-xl p-4 text-center shadow-sm">
          <code class="block text-orange-600 text-xs font-mono mb-2 break-all">{cmd}</code>
          <p class="text-gray-500 text-xs">{desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- トピック一覧 -->
  <section class="max-w-6xl mx-auto px-4 pb-16">
    <h2 class="text-2xl font-bold text-gray-900 mb-3">学習コンテンツ</h2>
    <p class="text-gray-500 mb-10">順番に読み進めることで、Git と GitHub の全体像が身に付きます。</p>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {topics.map(({ href, icon, title, description, color, border, text }) => (
        <a href={href}
           class={`group block bg-gradient-to-br ${color} border ${border} rounded-2xl p-6 hover:scale-[1.02] transition-transform shadow-sm`}>
          <div class="text-3xl mb-4">{icon}</div>
          <h3 class={`text-lg font-bold text-gray-900 mb-2 group-hover:${text} transition-colors`}>
            {title}
          </h3>
          <p class="text-gray-600 text-sm leading-relaxed">{description}</p>
          <div class={`mt-4 ${text} text-sm font-medium`}>
            読む →
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Gitとは？ -->
  <section class="bg-white border-y border-gray-200 py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">そもそも Git とは？</h2>
      <div class="grid md:grid-cols-2 gap-8">
        <div>
          <p class="text-gray-700 leading-relaxed mb-4">
            <strong class="text-gray-900">Git（ギット）</strong>はファイルの変更履歴を管理するツールです。
            「どのファイルを・いつ・どのように変えたか」を記録し、過去のバージョンに戻したり、
            複数人で同じコードを安全に編集できます。
          </p>
          <p class="text-gray-700 leading-relaxed">
            <strong class="text-gray-900">GitHub</strong>はその履歴をインターネット上で共有できるサービスです。
            チームメンバーと同じプロジェクトで作業したり、オープンソースのコードを公開・貢献できます。
          </p>
        </div>
        <div class="bg-slate-50 rounded-xl p-6 border border-gray-200">
          <h3 class="text-sm font-semibold text-gray-500 mb-4">Git なしの開発 vs Git あり</h3>
          <div class="space-y-3 text-sm">
            <div class="flex items-start gap-3">
              <span class="text-red-500 mt-0.5">✗</span>
              <span class="text-gray-600">report_final.docx, report_final2.docx, report_最終版.docx...</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-red-500 mt-0.5">✗</span>
              <span class="text-gray-600">「誰かが上書きした！」「どのバージョンが最新？」</span>
            </div>
            <div class="border-t border-gray-200 pt-3"></div>
            <div class="flex items-start gap-3">
              <span class="text-green-500 mt-0.5">✓</span>
              <span class="text-gray-700">すべての変更に日時・作者・理由が記録される</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-green-500 mt-0.5">✓</span>
              <span class="text-gray-700">いつでも以前の状態に戻せる</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-green-500 mt-0.5">✓</span>
              <span class="text-gray-700">複数人が同時に別々の機能を開発できる</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
