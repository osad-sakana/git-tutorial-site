---
import '../styles/global.css'

interface Props {
  title: string
  description?: string
}

const { title, description = 'GitとGitHubの使い方を初心者向けにわかりやすく解説します' } = Astro.props

const navLinks = [
  { href: '/',             label: 'ホーム' },
  { href: '/basics',       label: 'Git 基本' },
  { href: '/branch',       label: 'ブランチ' },
  { href: '/about-github', label: 'GitHub とは' },
  { href: '/github',       label: 'GitHub 基本操作' },
  { href: '/pullrequest',  label: 'プルリクエスト' },
  { href: '/workflow',     label: 'ワークフロー' },
  { href: '/issue-driven', label: 'Issue 駆動開発' },
]
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} | Git & GitHub 入門</title>
  </head>
  <body class="bg-gray-950 text-gray-100 min-h-screen font-sans">

    <!-- ヘッダー -->
    <header class="bg-gray-900 border-b border-gray-800 sticky top-0 z-50">
      <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">

        <!-- ロゴ -->
        <a href="/" class="flex items-center gap-3 hover:opacity-80 transition-opacity shrink-0">
          <div class="w-8 h-8 bg-orange-500 rounded-lg flex items-center justify-center text-white font-bold text-xs">
            Git
          </div>
          <span class="text-base font-bold text-white">Git & GitHub 入門</span>
        </a>

        <!-- デスクトップナビ -->
        <nav class="hidden lg:flex items-center gap-5 text-sm">
          {navLinks.map(({ href, label }) => (
            <a href={href} class="text-gray-400 hover:text-white transition-colors whitespace-nowrap">{label}</a>
          ))}
        </nav>

        <!-- ハンバーガーボタン（lg未満で表示） -->
        <button
          id="hamburger-btn"
          class="lg:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5 rounded-lg hover:bg-gray-800 transition-colors"
          aria-label="メニューを開く"
          aria-expanded="false"
        >
          <span class="hamburger-line block w-5 h-0.5 bg-gray-300 transition-all duration-300"></span>
          <span class="hamburger-line block w-5 h-0.5 bg-gray-300 transition-all duration-300"></span>
          <span class="hamburger-line block w-5 h-0.5 bg-gray-300 transition-all duration-300"></span>
        </button>
      </div>

      <!-- モバイルメニュー -->
      <div
        id="mobile-menu"
        class="hidden lg:hidden border-t border-gray-800 bg-gray-900"
      >
        <nav class="max-w-6xl mx-auto px-4 py-3 flex flex-col">
          {navLinks.map(({ href, label }) => (
            <a
              href={href}
              class="text-gray-400 hover:text-white hover:bg-gray-800 transition-colors px-3 py-2.5 rounded-lg text-sm"
            >{label}</a>
          ))}
        </nav>
      </div>
    </header>

    <!-- メインコンテンツ -->
    <main>
      <slot />
    </main>

    <!-- フッター -->
    <footer class="bg-gray-900 border-t border-gray-800 mt-20 py-10">
      <div class="max-w-6xl mx-auto px-4 text-center text-gray-500 text-sm">
        <p>Git & GitHub 入門ガイド — 初心者のためのバージョン管理学習サイト</p>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('hamburger-btn')
      const menu = document.getElementById('mobile-menu')
      const lines = btn?.querySelectorAll('.hamburger-line')

      btn?.addEventListener('click', () => {
        const isOpen = !menu?.classList.contains('hidden')

        if (isOpen) {
          menu?.classList.add('hidden')
          btn.setAttribute('aria-expanded', 'false')
          // 元のハンバーガー形状に戻す
          if (lines) {
            ;(lines[0] as HTMLElement).style.transform = ''
            ;(lines[1] as HTMLElement).style.opacity = '1'
            ;(lines[2] as HTMLElement).style.transform = ''
          }
        } else {
          menu?.classList.remove('hidden')
          btn.setAttribute('aria-expanded', 'true')
          // X 字に変形
          if (lines) {
            ;(lines[0] as HTMLElement).style.transform = 'translateY(8px) rotate(45deg)'
            ;(lines[1] as HTMLElement).style.opacity = '0'
            ;(lines[2] as HTMLElement).style.transform = 'translateY(-8px) rotate(-45deg)'
          }
        }
      })

      // ページ遷移時にメニューを閉じる
      document.querySelectorAll('#mobile-menu a').forEach((link) => {
        link.addEventListener('click', () => {
          menu?.classList.add('hidden')
          btn?.setAttribute('aria-expanded', 'false')
          if (lines) {
            ;(lines[0] as HTMLElement).style.transform = ''
            ;(lines[1] as HTMLElement).style.opacity = '1'
            ;(lines[2] as HTMLElement).style.transform = ''
          }
        })
      })
    </script>
  </body>
</html>
